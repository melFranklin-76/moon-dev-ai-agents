// Ross Cameron Momentum Trading Indicator Suite
// Based on Warrior Trading Strategy
// Version 2.0 - Updated to Pine Script v6

//@version=6
indicator("Ross Cameron Momentum Suite", overlay=true, max_labels_count=50)

// ============================================================================
// INPUT PARAMETERS
// ============================================================================

// Moving Averages
show_emas = input.bool(true, "Show EMAs", group="Moving Averages")
ema9_period = input.int(9, "EMA 9 Period", group="Moving Averages")
ema20_period = input.int(20, "EMA 20 Period", group="Moving Averages")
sma50_period = input.int(50, "SMA 50 Period", group="Moving Averages")
sma200_period = input.int(200, "SMA 200 Period", group="Moving Averages")

// VWAP
show_vwap = input.bool(true, "Show VWAP", group="VWAP")

// Entry Signals
show_signals = input.bool(true, "Show Entry Signals", group="Signals")
rsi_threshold = input.int(50, "RSI Threshold for Bullish", minval=0, maxval=100, group="Signals")

// Alerts
enable_alerts = input.bool(true, "Enable Alerts", group="Alerts")

// ============================================================================
// CALCULATIONS
// ============================================================================

// Moving Averages
ema9 = ta.ema(close, ema9_period)
ema20 = ta.ema(close, ema20_period)
sma50 = ta.sma(close, sma50_period)
sma200 = ta.sma(close, sma200_period)

// VWAP
vwap = ta.vwap(close)

// RSI
rsi = ta.rsi(close, 14)

// MACD
[macdLine, signalLine, histLine] = ta.macd(close, 12, 26, 9)

// ATR for volatility
atr = ta.atr(14)

// Relative Volume (current volume vs 30-day average)
avg_volume = ta.sma(volume, 30)
rel_volume = volume / avg_volume

// Daily Change %
daily_change = ((close - close[1]) / close[1]) * 100

// ============================================================================
// TREND CONDITIONS
// ============================================================================

// Bullish Trend Conditions
price_above_ema9 = close > ema9
price_above_ema20 = close > ema20
price_above_vwap = close > vwap
ema9_above_ema20 = ema9 > ema20

// Momentum Conditions
rsi_bullish = rsi > rsi_threshold
macd_bullish = macdLine > signalLine
volume_spike = rel_volume >= 2.0

// Strong Bullish Setup (all conditions met)
strong_bullish = price_above_ema9 and price_above_ema20 and price_above_vwap and
                 ema9_above_ema20 and rsi_bullish and macd_bullish and volume_spike

// Pullback to Support (potential entry)
pullback_to_ema9 = close <= ema9 and close >= ema9 * 0.98 and rsi_bullish
pullback_to_vwap = close <= vwap and close >= vwap * 0.98 and rsi_bullish

// Entry Signal
entry_signal = (pullback_to_ema9 or pullback_to_vwap) and macd_bullish and volume_spike

// ============================================================================
// PLOTTING
// ============================================================================

// Moving Averages
plot(show_emas ? ema9 : na, "EMA 9", color=color.new(color.blue, 0), linewidth=2)
plot(show_emas ? ema20 : na, "EMA 20", color=color.new(color.red, 0), linewidth=2)
plot(show_emas ? sma50 : na, "SMA 50", color=color.new(color.orange, 0), linewidth=1)
plot(show_emas ? sma200 : na, "SMA 200", color=color.new(color.purple, 0), linewidth=1)

// VWAP
plot(show_vwap ? vwap : na, "VWAP", color=color.new(color.yellow, 0), linewidth=2, style=plot.style_circles)

// Background color for strong bullish conditions
bgcolor(strong_bullish ? color.new(color.green, 90) : na, title="Strong Bullish Background")

// Entry Signals
plotshape(show_signals and entry_signal, "Entry Signal", shape.triangleup, location.belowbar,
          color=color.new(color.green, 0), size=size.small, text="ENTRY")

// ============================================================================
// INFO TABLE
// ============================================================================

// Create info table
var table info_table = table.new(position.top_right, 2, 10, border_width=1)

if barstate.islast
    // Header
    table.cell(info_table, 0, 0, "Metric", bgcolor=color.new(color.gray, 70), text_color=color.white)
    table.cell(info_table, 1, 0, "Value", bgcolor=color.new(color.gray, 70), text_color=color.white)

    // RSI
    rsi_color = rsi > 70 ? color.red : rsi < 30 ? color.green : color.gray
    table.cell(info_table, 0, 1, "RSI (14)", bgcolor=color.new(color.gray, 90))
    table.cell(info_table, 1, 1, str.tostring(rsi, "#.##"), bgcolor=color.new(rsi_color, 80))

    // Relative Volume
    rel_vol_color = rel_volume >= 2.0 ? color.green : color.gray
    table.cell(info_table, 0, 2, "Rel Volume", bgcolor=color.new(color.gray, 90))
    table.cell(info_table, 1, 2, str.tostring(rel_volume, "#.##") + "x", bgcolor=color.new(rel_vol_color, 80))

    // Daily Change
    change_color = daily_change >= 3 ? color.green : daily_change < 0 ? color.red : color.gray
    table.cell(info_table, 0, 3, "Daily %", bgcolor=color.new(color.gray, 90))
    table.cell(info_table, 1, 3, str.tostring(daily_change, "#.##") + "%", bgcolor=color.new(change_color, 80))

    // ATR
    table.cell(info_table, 0, 4, "ATR (14)", bgcolor=color.new(color.gray, 90))
    table.cell(info_table, 1, 4, str.tostring(atr, "#.##"), bgcolor=color.new(color.gray, 80))

    // Price vs EMA9
    price_ema9_color = price_above_ema9 ? color.green : color.red
    table.cell(info_table, 0, 5, "Above EMA9", bgcolor=color.new(color.gray, 90))
    table.cell(info_table, 1, 5, price_above_ema9 ? "YES" : "NO", bgcolor=color.new(price_ema9_color, 80))

    // Price vs EMA20
    price_ema20_color = price_above_ema20 ? color.green : color.red
    table.cell(info_table, 0, 6, "Above EMA20", bgcolor=color.new(color.gray, 90))
    table.cell(info_table, 1, 6, price_above_ema20 ? "YES" : "NO", bgcolor=color.new(price_ema20_color, 80))

    // Price vs VWAP
    price_vwap_color = price_above_vwap ? color.green : color.red
    table.cell(info_table, 0, 7, "Above VWAP", bgcolor=color.new(color.gray, 90))
    table.cell(info_table, 1, 7, price_above_vwap ? "YES" : "NO", bgcolor=color.new(price_vwap_color, 80))

    // MACD Signal
    macd_color = macd_bullish ? color.green : color.red
    table.cell(info_table, 0, 8, "MACD", bgcolor=color.new(color.gray, 90))
    table.cell(info_table, 1, 8, macd_bullish ? "BULLISH" : "BEARISH", bgcolor=color.new(macd_color, 80))

    // Overall Signal
    signal_color = strong_bullish ? color.green : color.red
    table.cell(info_table, 0, 9, "SETUP", bgcolor=color.new(color.gray, 70), text_color=color.white)
    table.cell(info_table, 1, 9, strong_bullish ? "STRONG" : "WAIT", bgcolor=color.new(signal_color, 70), text_color=color.white)

// ============================================================================
// ALERTS
// ============================================================================

alertcondition(entry_signal, title="Entry Signal", message="Ross Cameron Entry Signal: {{ticker}} - Pullback to support with momentum")
alertcondition(strong_bullish, title="Strong Bullish Setup", message="Ross Cameron Strong Bullish: {{ticker}} - All conditions met")
alertcondition(volume_spike, title="Volume Spike", message="Volume Spike: {{ticker}} - Relative volume >= 2x")
alertcondition(daily_change >= 3, title="3% Gainer", message="3% Gainer: {{ticker}} - Up {{close}}%")

// ============================================================================
// INSTALLATION INSTRUCTIONS
// ============================================================================

// HOW TO USE THIS INDICATOR:
//
// 1. Copy this entire script
// 2. Go to TradingView.com
// 3. Open any stock chart
// 4. Click "Pine Editor" at bottom of chart
// 5. Click "New" → "Indicator"
// 6. Delete all default code
// 7. Paste this script
// 8. Click "Save" and name it "Ross Cameron Momentum Suite"
// 9. Click "Add to Chart"
//
// The indicator provides:
// ✅ EMA 9, 20, 50, 200 overlays (Blue, Red, Orange, Purple)
// ✅ VWAP overlay (Yellow)
// ✅ Entry signal markers (Green triangles)
// ✅ Real-time info table with all key metrics
// ✅ Background highlighting for strong bullish setups
// ✅ Customizable alerts for entry signals
//
// Color Legend:
// - Blue: 9 EMA (fast moving average)
// - Red: 20 EMA (medium moving average)
// - Orange: 50 SMA (support/resistance)
// - Purple: 200 SMA (long-term trend)
// - Yellow: VWAP (volume-weighted average price)
// - Green Triangle: Entry signal detected
// - Green Background: All bullish conditions met
//
// For the separate Momentum Scorecard indicator:
// - See the file: momentum-scorecard.pine
// - Install it as a second indicator below your chart
