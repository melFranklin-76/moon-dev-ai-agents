// Ross Cameron Momentum Scorecard
// Displays a 0-10 score based on momentum criteria
// Version 2.0 - Updated to Pine Script v6

//@version=6
indicator("Momentum Scorecard", overlay=false)

// ============================================================================
// MOMENTUM SCORE CALCULATION (0-10 points)
// ============================================================================

// Initialize score
var int score = 0
score := 0

// Price above 9 EMA (1 point)
score := score + (close > ta.ema(close, 9) ? 1 : 0)

// Price above 20 EMA (1 point)
score := score + (close > ta.ema(close, 20) ? 1 : 0)

// Price above VWAP (1 point)
score := score + (close > ta.vwap(close) ? 1 : 0)

// 9 EMA above 20 EMA (1 point)
score := score + (ta.ema(close, 9) > ta.ema(close, 20) ? 1 : 0)

// RSI above 50 (1 point)
score := score + (ta.rsi(close, 14) > 50 ? 1 : 0)

// MACD bullish (1 point)
[macd_line, signal_line, hist] = ta.macd(close, 12, 26, 9)
score := score + (macd_line > signal_line ? 1 : 0)

// Relative volume >= 2.0 (2 points - double weight)
rel_vol = volume / ta.sma(volume, 30)
score := score + (rel_vol >= 2.0 ? 2 : 0)

// Daily gain >= 3% (2 points - double weight)
daily_pct = ((close - close[1]) / close[1]) * 100
score := score + (daily_pct >= 3 ? 2 : 0)

// ============================================================================
// SCORING LEVELS
// ============================================================================
// 8-10: STRONG bullish momentum (take trades)
// 5-7:  MODERATE momentum (be cautious)
// 0-4:  WEAK momentum (avoid trading)

// ============================================================================
// PLOTTING
// ============================================================================

// Plot score with color based on strength
score_color = score >= 8 ? color.green : score >= 5 ? color.yellow : color.red
plot(score, "Momentum Score", color=score_color, linewidth=3, style=plot.style_line)

// Horizontal lines for thresholds
hline(8, "Strong Threshold", color=color.new(color.green, 50), linestyle=hline.style_dashed, linewidth=1)
hline(5, "Neutral", color=color.new(color.yellow, 50), linestyle=hline.style_dashed, linewidth=1)
hline(10, "Max", color=color.new(color.gray, 70), linestyle=hline.style_solid, linewidth=1)
hline(0, "Min", color=color.new(color.gray, 70), linestyle=hline.style_solid, linewidth=1)

// Background colors
bgcolor(score >= 8 ? color.new(color.green, 85) : score <= 3 ? color.new(color.red, 85) : na, title="Score Background")

// ============================================================================
// INFO TABLE
// ============================================================================

var table score_table = table.new(position.top_right, 2, 4, border_width=1)

if barstate.islast
    // Header
    table.cell(score_table, 0, 0, "Score", bgcolor=color.new(color.gray, 70), text_color=color.white)
    table.cell(score_table, 1, 0, str.tostring(score) + " / 10", bgcolor=color.new(score_color, 70), text_color=color.white)

    // Status
    status_text = score >= 8 ? "STRONG" : score >= 5 ? "MODERATE" : "WEAK"
    table.cell(score_table, 0, 1, "Status", bgcolor=color.new(color.gray, 90))
    table.cell(score_table, 1, 1, status_text, bgcolor=color.new(score_color, 80), text_color=color.white)

    // Relative Volume
    table.cell(score_table, 0, 2, "Rel Vol", bgcolor=color.new(color.gray, 90))
    table.cell(score_table, 1, 2, str.tostring(rel_vol, "#.##") + "x",
               bgcolor=color.new(rel_vol >= 2.0 ? color.green : color.gray, 80))

    // Daily %
    table.cell(score_table, 0, 3, "Daily %", bgcolor=color.new(color.gray, 90))
    table.cell(score_table, 1, 3, str.tostring(daily_pct, "#.##") + "%",
               bgcolor=color.new(daily_pct >= 3 ? color.green : color.gray, 80))

// ============================================================================
// ALERTS
// ============================================================================

alertcondition(score >= 8 and score[1] < 8, title="Strong Momentum", message="{{ticker}} - Momentum Score reached 8+")
alertcondition(score < 5 and score[1] >= 5, title="Weak Momentum", message="{{ticker}} - Momentum Score dropped below 5")

// ============================================================================
// INSTALLATION INSTRUCTIONS
// ============================================================================

// HOW TO USE THIS INDICATOR:
//
// 1. Copy this entire script
// 2. Go to TradingView.com
// 3. Open a stock chart
// 4. Click "Pine Editor" at bottom
// 5. Click "New" → "Indicator"
// 6. Delete default code and paste this script
// 7. Click "Save" and name it "Momentum Scorecard"
// 8. Click "Add to Chart"
//
// This indicator shows a momentum score from 0-10:
//
// 🟢 8-10 = STRONG momentum (ideal for trading)
// 🟡 5-7  = MODERATE momentum (be selective)
// 🔴 0-4  = WEAK momentum (avoid)
//
// Scoring Breakdown:
// +1 point: Price above 9 EMA
// +1 point: Price above 20 EMA
// +1 point: Price above VWAP
// +1 point: 9 EMA above 20 EMA
// +1 point: RSI above 50
// +1 point: MACD bullish
// +2 points: Relative volume >= 2x
// +2 points: Daily gain >= 3%
//
// Use this with the main "Ross Cameron Momentum Suite" indicator
// for complete analysis!
//
// ⚠️ OPTIONS LIQUIDITY NOTE ($250 account):
// This score tells you momentum direction — but before buying options,
// always verify the options chain has:
//   • Open interest > 200 contracts on your strike
//   • Bid/ask spread < 10% of the premium
//   • Stock price > $5 (sub-$5 stocks rarely have liquid options)
// Low float stocks ($2–$20, <10M shares) that Ross Cameron trades
// often have NO liquid options — confirm on Webull before entering.
